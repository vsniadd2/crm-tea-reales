# Скопируйте в .env в корне проекта на сервере:
#   cp .env.example .env
#   nano .env
#
# Сгенерировать JWT_SECRET:
#   openssl rand -hex 32

# --- Сервер ---
SERVER_IP=93.125.82.249
FRONTEND_PORT=80
BACKEND_PORT=3001
NODE_ENV=production

# --- PostgreSQL (данные в volume tea_crm_postgres_data) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_СИЛЬНЫЙ_ПАРОЛЬ
POSTGRES_DB=tea_crm

# --- JWT ---
# JWT_SECRET         — подпись access-токена (24ч)
# JWT_REFRESH_SECRET — подпись refresh-токена (7д)
JWT_SECRET=ЗАМЕНИТЕ_openssl_rand_hex_32
JWT_REFRESH_SECRET=ЗАМЕНИТЕ_openssl_rand_hex_32
